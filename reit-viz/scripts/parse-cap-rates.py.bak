#!/usr/bin/env python3
"""
Parse REIT-implied-cap-rate.xlsx and merge implied cap rates
into existing ticker data files.

Each ticker sheet has:
- Row 4: headers (Week, Price, Shares, Mkt Cap, Net Debt, EV, LTM NOI, Implied CR, ...)
- Rows 5-280: data (weekly Fridays)
- Col A = date, Col H = Implied Cap Rate

Only includes rows where col A is a valid date AND col H is a numeric value.
Maps weekly dates to the nearest date index in the existing dates.json.
"""

import json
import os
import sys
from datetime import datetime

try:
    import openpyxl
except ImportError:
    print("ERROR: openpyxl not installed", file=sys.stderr)
    sys.exit(1)

WORKBOOK_PATH = sys.argv[1] if len(sys.argv) > 1 else "REIT-implied-cap-rate.xlsx"
DATA_DIR = sys.argv[2] if len(sys.argv) > 2 else "data"

# Load existing dates index
dates_path = os.path.join(DATA_DIR, "dates.json")
with open(dates_path) as f:
    dates_list = json.load(f)  # list of "YYYY-MM-DD" strings

# Build date -> index lookup
date_to_idx = {d: i for i, d in enumerate(dates_list)}

# Also build a sorted list for nearest-date matching (weekly dates may not align with daily)
sorted_dates = sorted(date_to_idx.keys())

def find_nearest_date_idx(target_str):
    """Find the index of the nearest date in the dates array."""
    if target_str in date_to_idx:
        return date_to_idx[target_str]
    # Binary search for nearest
    lo, hi = 0, len(sorted_dates) - 1
    while lo < hi:
        mid = (lo + hi) // 2
        if sorted_dates[mid] < target_str:
            lo = mid + 1
        else:
            hi = mid
    # Check lo and lo-1 for closest
    best = lo
    if lo > 0:
        d_lo = abs((datetime.strptime(sorted_dates[lo], "%Y-%m-%d") - datetime.strptime(target_str, "%Y-%m-%d")).days)
        d_prev = abs((datetime.strptime(sorted_dates[lo-1], "%Y-%m-%d") - datetime.strptime(target_str, "%Y-%m-%d")).days)
        if d_prev < d_lo:
            best = lo - 1
    return date_to_idx[sorted_dates[best]]

# Parse workbook
print(f"Opening workbook: {WORKBOOK_PATH}")
wb = openpyxl.load_workbook(WORKBOOK_PATH, read_only=True, data_only=True)

# Identify ticker sheets (uppercase, 1-5 chars, not known non-ticker sheets)
NON_TICKER_SHEETS = {
    '__FDSCACHE__', 'FFO multiples ', 'Correlation Analysis', 'Rolling Corr Charts',
    'NW Calc', 'Summary', 'FactSet Prices', 'FS Shares', 'FS Net Debt', 'FS NOI',
    'Spread Charts', 'Acq Cap Rate', 'Cost of Debt', 'Earnings Dates',
    '10Yr Yield', 'Cap Rate vs 10Yr', 'Spread Charts 10Yr'
}

ticker_sheets = [s for s in wb.sheetnames if s not in NON_TICKER_SHEETS and s.replace('.', '').isupper() and 1 <= len(s) <= 5]
print(f"Found {len(ticker_sheets)} ticker sheets: {ticker_sheets[:10]}...")

# Load existing tickers.json to know which tickers we have
tickers_path = os.path.join(DATA_DIR, "tickers.json")
with open(tickers_path) as f:
    tickers_meta = json.load(f)

existing_tickers = {t["ticker"] for t in tickers_meta}

stats = {"updated": 0, "skipped_no_file": 0, "skipped_no_data": 0, "total_points": 0}

for sheet_name in ticker_sheets:
    # Check if ticker exists in our data
    ticker_file = os.path.join(DATA_DIR, "tickers", f"{sheet_name}.json")
    if not os.path.exists(ticker_file):
        print(f"  {sheet_name}: no data file, skipping")
        stats["skipped_no_file"] += 1
        continue

    ws = wb[sheet_name]
    
    # Extract valid rows: col A = date, col H = numeric implied cap rate
    cap_rate_points = []  # list of (date_str, value)
    for row in ws.iter_rows(min_row=5, max_row=280, values_only=True):
        date_val = row[0]  # col A
        cr_val = row[7] if len(row) > 7 else None  # col H (0-indexed: 7)
        
        # Skip if date isn't a datetime
        if not isinstance(date_val, datetime):
            continue
        # Skip if cap rate isn't numeric
        if not isinstance(cr_val, (int, float)):
            continue
        # Skip NaN/inf
        if cr_val != cr_val or cr_val == float('inf') or cr_val == float('-inf'):
            continue
            
        date_str = date_val.strftime("%Y-%m-%d")
        cap_rate_points.append((date_str, cr_val))
    
    if not cap_rate_points:
        print(f"  {sheet_name}: no valid cap rate data, skipping")
        stats["skipped_no_data"] += 1
        continue
    
    # Load existing ticker data file
    with open(ticker_file) as f:
        ticker_data = json.load(f)
    
    # Build the "Implied Cap Rate" metric as a flat array aligned to the dates index
    # The existing data uses flat arrays where index = date index
    total_dates = len(dates_list)
    
    # Use RLE encoding like other metrics: flat array with ~N for consecutive nulls
    # First build a dense array
    dense = [None] * total_dates
    mapped_count = 0
    for date_str, value in cap_rate_points:
        idx = find_nearest_date_idx(date_str)
        if 0 <= idx < total_dates:
            dense[idx] = round(value * 100, 4)  # Convert decimal to percentage (e.g., 0.05 -> 5.0%)
            mapped_count += 1
    
    # RLE encode
    encoded = []
    null_run = 0
    for v in dense:
        if v is None:
            null_run += 1
        else:
            if null_run > 0:
                encoded.append(f"~{null_run}")
                null_run = 0
            encoded.append(v)
    if null_run > 0:
        encoded.append(f"~{null_run}")
    
    # Add to ticker data
    ticker_data["Implied Cap Rate"] = encoded
    
    # Write back
    with open(ticker_file, "w") as f:
        json.dump(ticker_data, f)
    
    # Update tickers.json metadata to include the new metric
    for t in tickers_meta:
        if t["ticker"] == sheet_name and "Implied Cap Rate" not in t["metrics"]:
            t["metrics"].append("Implied Cap Rate")
    
    print(f"  {sheet_name}: {mapped_count} cap rate points added (from {len(cap_rate_points)} weekly observations)")
    stats["updated"] += 1
    stats["total_points"] += mapped_count

wb.close()

# Write updated tickers.json
with open(tickers_path, "w") as f:
    json.dump(tickers_meta, f)

print(f"\nDone: {stats['updated']} tickers updated, {stats['skipped_no_file']} skipped (no file), {stats['skipped_no_data']} skipped (no data)")
print(f"Total cap rate data points: {stats['total_points']}")
